{
    "name": "hugocenturio/henco",
    "description": "Order manager for field workers",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.0",
        "ext-mysqli": "*",
        "phpmailer/phpmailer": "^6.9",
        "mailjet/mailjet-apiv3-php": "^1.6",
        "dompdf/dompdf": "^3.0",
        "guzzlehttp/guzzle": "^7.9"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.11"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "files": [
            "app/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test":    "phpunit --colors=always",
        "stan":    "phpstan analyse --memory-limit=512M",
        "lint":    [ "@stan", "@test" ]
    },
    "config": {
        "sort-packages": true
    }
}
