# Real configuration (contains credentials)
/config/config.php
/.env

# IDE / editor
/.vscode/
/.idea/
*.code-workspace

# Project Idx (Google) workspace metadata
/.idx/

# Claude Code session/local state
/.claude/

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
/logs/*
!/logs/.gitkeep

# Tooling caches
/.phpunit.cache/
/.phpunit.result.cache
/.phpstan/
/.php_cs.cache

# Uploads — keep folder, ignore user-uploaded content
/uploads/product_images/*
!/uploads/product_images/.gitkeep

# PHP runtime
*.cache
